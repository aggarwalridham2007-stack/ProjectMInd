# Application
APP_NAME=ProjectMind
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4
RELOAD=true

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://projectmind:projectmind@localhost:5432/projectmind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Database - Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DATABASE=neo4j

# Database - ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSISTENCE_DIR=/data/chromadb

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# Logging
LOG_FORMAT=json
LOG_FILE=/logs/projectmind.log

# External APIs
ARXIV_API_BASE=https://api.arxiv.org/v1/query
CROSSREF_API_BASE=https://api.crossref.org
SEMANTIC_SCHOLAR_API_BASE=https://api.semanticscholar.org/graph/v1
